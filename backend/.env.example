# ============================================================
# VARIABLES DE ENTORNO — PLANTILLA
# Copia este archivo como .env.docker para desarrollo local
# Configura los valores reales en Railway (producción)
# NUNCA commitear archivos con secretos reales
# ============================================================

# ============================================================
# SERVIDOR
# ============================================================
PORT=3001
NODE_ENV=development   # development | production

# ============================================================
# BASE DE DATOS PostgreSQL
# ============================================================
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/db_sersa
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=<REEMPLAZA>
DB_NAME=db_sersa
DB_SSL=false
# En Railway con proxy público, el cert es autofirmado → poner false
# En conexión directa con CA conocida → poner true
DB_SSL_REJECT_UNAUTHORIZED=true

# ============================================================
# AUTENTICACIÓN JWT
# Generar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================
JWT_SECRET=<REEMPLAZA_CON_128_CHARS_HEX>
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# ENCRIPTACIÓN AES-256 para certificados en BD
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# O usar: node backend/scripts/generate-encryption-key.js
# ============================================================
ENCRYPTION_KEY=<REEMPLAZA_CON_64_CHARS_HEX>

# ============================================================
# CORS — URLs permitidas (separadas por coma)
# ============================================================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================
# AFIP — configuración migrada a tabla app_settings en BD
# Editar desde el panel de administración: GET/PUT /api/app-settings
# Variables de fallback para desarrollo local (opcionales en producción)
# ============================================================
# DEPRECATED — usar app_settings: AFIP_WSAA_URL
# AFIP_WSAA_URL=https://wsaa.afip.gov.ar/ws/services/LoginCms?wsdl
# DEPRECATED — usar app_settings: AFIP_WSCERT_WSDL
# AFIP_WSCERT_WSDL=https://wsaa.afip.gov.ar/controladores-fiscales-ws/CertificadosService/CertificadosBean?wsdl
# DEPRECATED — usar app_settings: AFIP_CUIT
# AFIP_CUIT=<CUIT_DE_LA_EMPRESA>
# DEPRECATED — usar app_settings: AFIP_FABRICANTE
# AFIP_FABRICANTE=SE
# DEPRECATED — certificado PFX y Root_RTI se suben desde el panel de admin
# AFIP_CERT_PATH=./certs/certificado.pfx
# AFIP_KEY_PASSWORD=<PASSWORD_DEL_CERTIFICADO_PFX>
# AFIP_ROOT_PATH=./certs/Root_RTI.txt

# ============================================================
# RATE LIMITING
# ============================================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================================
# NOTIFICACIONES
# ============================================================
NOTIFICATION_LIMIT=8
ADMIN_MAIL_USER=<EMAIL_REMITENTE>
ADMIN_MAIL_PASS=<APP_PASSWORD_GMAIL>
ADMIN_MAIL_TO=<EMAIL_DESTINO_ADMIN>

# ============================================================
# USUARIOS
# Contraseña por defecto asignada al resetear un usuario
# Generar: node -e "require('crypto').randomBytes(12).toString('base64')"
# ============================================================
DEFAULT_USER_PASSWORD=<REEMPLAZA_CON_PASSWORD_DEFAULT>

# ============================================================
# OTROS
# ============================================================
MOCK_MODE=false
